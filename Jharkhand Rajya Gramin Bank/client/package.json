    "dev": "pnpm api-type-gen && vite",
    "preinstall": "npx only-allow pnpm",
    "generate-routes": "tsr generate",
    "build": "pnpm api-type-gen && pnpm generate-routes && tsgo -b --noEmit && vite build",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix --fix-suggestions && eslint . --fix",
    "preview": "vite preview",
    "format": "prettier --check . --experimental-cli",
    "format:write": "prettier --write . --experimental-cli",
    "check": "pnpm format && pnpm lint",
    "fix": "pnpm format:write && pnpm lint:fix",
    "api-type-gen": "openapi-typescript https://tgb.ssbi.tech/backend/v3/api-docs -o ./src/types/api/v1.d.ts",
    "knip": "knip",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}": "oxlint --fix --fix-suggestions",
